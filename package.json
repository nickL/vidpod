{
  "name": "vidpod",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src drizzle.config.ts eslint.config.mjs",
    "test": "vitest run src",
    "cf:deploy:hls": "pnpm --dir cloudflare/hls-worker exec wrangler deploy",
    "cf:deploy:jobs": "pnpm --dir cloudflare/media-jobs-worker exec wrangler deploy",
    "cf:deploy:mp4": "pnpm exec wrangler deploy -c cloudflare/mp4-exporter/wrangler.jsonc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@base-ui/react": "^1.3.0",
    "@neondatabase/serverless": "^1.0.2",
    "@tanstack/react-query": "^5.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hls.js": "^1.6.15",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
